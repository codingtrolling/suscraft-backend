<Window x:Class="SUSCRAFT.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SUSCRAFT Settings" Height="350" Width="400"
        Background="#1E1E1E" Foreground="White">
    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="Launcher Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="RAM Allocation (MB):" Margin="0,5"/>
            <TextBox x:Name="RamBox" Text="2048" Background="#333" Foreground="White" BorderThickness="1" Padding="5"/>
            
            <TextBlock Text="Custom Java Path (Optional):" Margin="0,15,0,5"/>
            <TextBox x:Name="JavaBox" Background="#333" Foreground="White" BorderThickness="1" Padding="5"/>

            <Button Content="Save Settings" Margin="0,20" Height="30" Background="#FF4500" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Border>
</Window>
