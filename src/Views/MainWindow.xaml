<Window x:Class="SUSCRAFT.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SUSCRAFT" Height="500" Width="900"
        Background="#1E1E1E" Foreground="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#252526" Padding="15">
            <StackPanel>
                <TextBlock Text="SUSCRAFT" MouseDown="Logo_MouseDown" Cursor="Hand"
                           FontSize="24" FontWeight="Bold" Margin="0,0,0,30" Foreground="#FF4500"/>
                
                <Button Content="PLAY" Height="40" Background="#FF4500" Foreground="White" 
                        FontWeight="Bold" Margin="0,10" Click="PlayButton_Click"/>
                
                <Button Content="Add Instance" Margin="0,5" Background="#333" Foreground="White" 
                        Click="AddInstance_Click"/> <Button Content="Settings" Margin="0,5" Background="#333" Foreground="White" 
                        Click="Settings_Click"/> </StackPanel>
        </Border>

        <ListBox Grid.Column="1" ItemsSource="{Binding Instances}" 
                 SelectedItem="{Binding SelectedInstance, Mode=TwoWay}"
                 Background="Transparent" BorderThickness="0">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Margin="10"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="10" Width="120">
                        <Border Background="#444" Height="100" CornerRadius="8">
                            <TextBlock Text="SUS" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" Margin="0,5,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
