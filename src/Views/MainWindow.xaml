<Window x:Class="Suscraft.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SUSCRAFT Launcher" Height="500" Width="900"
        Background="#1E1E1E" Foreground="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/> <ColumnDefinition Width="*"/>   </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#252526">
            <StackPanel>
                <TextBlock Text="SUSCRAFT" FontSize="22" Margin="10,20,10,20" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#007ACC"/>
                <Button Content="Instances" Margin="10,5" Padding="10" Background="Transparent" Foreground="White" BorderThickness="0"/>
                <Button Content="Accounts" Margin="10,5" Padding="10" Background="Transparent" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <StackPanel VerticalAlignment="Bottom" Margin="15">
                <Border Background="#333" CornerRadius="5" Padding="10">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="32" Height="32" Fill="#555" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Offline Player" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="LSO: Taran Taran" FontSize="9" Foreground="#4CAF50"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Column="1" Margin="30">
            <TextBlock Text="Welcome to SUSCRAFT" FontSize="24" Margin="0,0,0,20"/>
            
            <ComboBox x:Name="VersionSelector" Width="250" HorizontalAlignment="Left" Margin="0,0,0,10" IsEditable="True" Text="Select Version..."/>
            
            <Button Content="INSTALL &amp; PLAY" Width="180" Height="45" HorizontalAlignment="Left" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
