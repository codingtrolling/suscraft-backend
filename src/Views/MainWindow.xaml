<Grid Grid.Column="0" Background="#252526">
    <StackPanel>
        <TextBlock Text="SUSCRAFT" FontSize="20" Margin="10" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#007ACC"/>
        <Button Content="Instances" Margin="5" Style="{StaticResource SidebarButtonStyle}"/>
        <Button Content="Accounts" Margin="5" Style="{StaticResource SidebarButtonStyle}"/>
    </StackPanel>

    <StackPanel VerticalAlignment="Bottom" Margin="10">
        <Border Background="#333" CornerRadius="5" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="32" Height="32" Fill="#555" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock x:Name="ActiveUsername" Text="Offline Player" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="Premium Account" FontSize="10" Foreground="Gray"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <TextBlock Text="LSO: Taran Taran [SECURED]" FontSize="9" HorizontalAlignment="Center" Margin="5" Foreground="#4CAF50"/>
    </StackPanel>
</Grid>
